{
  "name": "characterarc",
  "version": "1.10.0",
  "description": "CharacterArc desktop writing studio",
  "packageManager": "pnpm@10.33.2",
  "main": "./dist-electron/main/index.js",
  "author": "zhouyeshan <zhouyeshan@users.noreply.github.com>",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "vue-tsc --noEmit",
    "build": "pnpm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "dist": "pnpm run build && cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder",
    "dist:win": "pnpm run build && cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win",
    "dist:mac": "pnpm run build && cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --mac"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/openai": "^3.0.64",
    "@node-rs/jieba": "^2.0.1",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-character-count": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@tiptap/vue-3": "^3.22.5",
    "ai": "^6.0.184",
    "cytoscape": "^3.33.3",
    "diff2html": "^3.4.56",
    "docx": "^9.6.1",
    "dompurify": "^3.4.7",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "lucide-vue-next": "^0.525.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.3",
    "naive-ui": "^2.43.1",
    "pinia": "^3.0.3",
    "vue": "^3.5.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/node": "^24.3.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "cross-env": "^7.0.3",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.0",
    "vue-tsc": "^3.0.5"
  },
  "build": {
    "appId": "com.characterarc.desktop",
    "productName": "CharacterArc",
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "out/**",
      "dist-electron/**",
      "node_modules/@node-rs/**",
      "resources/**/*",
      "!node_modules/**/src/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/doc/**",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/__tests__/**",
      "!node_modules/**/example/**",
      "!node_modules/**/examples/**",
      "!node_modules/**/*.map",
      "!node_modules/**/*.ts",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/*.d.mts",
      "!node_modules/**/*.d.cts",
      "!node_modules/**/README*",
      "!node_modules/**/CHANGELOG*"
    ],
    "asarUnpack": [
      "node_modules/@node-rs/**"
    ],
    "afterPack": "build/afterPack.cjs",
    "mac": {
      "icon": "resources/icon.png",
      "category": "public.app-category.productivity",
      "identity": "-",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052",
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "linux": {
      "icon": "resources/icon.png",
      "category": "Office",
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    }
  },
  "optionalDependencies": {
    "@node-rs/jieba-darwin-arm64": "2.0.1",
    "@node-rs/jieba-darwin-x64": "2.0.1",
    "@node-rs/jieba-win32-x64-msvc": "2.0.1",
    "@node-rs/jieba-win32-arm64-msvc": "2.0.1",
    "@node-rs/jieba-linux-x64-gnu": "2.0.1",
    "@node-rs/jieba-linux-arm64-gnu": "2.0.1"
  }
}
